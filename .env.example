# BMAD-Doc-AI Desktop Agent Konfiguration
# Kopiere als .env und trage deine Werte ein.

# Server-Verbindung
BMAD_SERVER_URL=https://docai.pixel-by-design.de
BMAD_EMAIL=deine@email.de
BMAD_PASSWORD=dein-passwort

# Ordner der überwacht wird (wird automatisch erstellt)
BMAD_WATCH_DIR=~/Documents/BMAD-Eingang

# Verhalten
BMAD_DELETE_AFTER_UPLOAD=false
BMAD_MOVE_AFTER_UPLOAD=true
BMAD_FILE_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff,.tif,.docx
BMAD_POLL_INTERVAL=2.0
